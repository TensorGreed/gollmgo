{
  "host": "0.0.0.0",
  "port": 8080,

  "_model": "Either an HF repo id (owner/name[@rev]) or a local path.",
  "model_path": "meta-llama/Llama-3.2-3B-Instruct",
  "tokenizer_path": "",

  "_cache": "HF cache dir override. Empty => ~/.cache/gollmgo/hub.",
  "hf_cache_dir": "",
  "_auth": "HF bearer token. Empty => reads $HF_TOKEN / $HUGGING_FACE_HUB_TOKEN.",
  "hf_token": "",

  "_scheduler": "Policy: fcfs | sjf | priority.",
  "scheduler_policy": "fcfs",
  "_preempt": "Mode: recompute | swap. Swap requires a KVSwapper-capable runner.",
  "preempt_mode": "recompute",
  "auto_preempt": false,

  "max_batch_size": 64,
  "max_token_budget": 4096,
  "max_queue_depth": 256,
  "prefill_chunk_size": 512,

  "block_size": 16,
  "max_memory_fraction": 0.9,

  "_prefix_cache": "Block-level prefix cache for KV reuse on repeated prompts.",
  "prefix_caching": false,
  "prefix_cache_max_blocks": 0,

  "_quantization": "One of: \"\", \"fp8\", \"int8\".",
  "quantization": "",

  "speculative": {
    "enabled": false,
    "mode": "ngram",
    "ngram_size": 3,
    "num_draft_tokens": 4,
    "kill_threshold": 0
  },

  "log_level": "info"
}
